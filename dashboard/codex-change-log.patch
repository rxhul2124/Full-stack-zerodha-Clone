+++ b/dashboard/src/kite/sidebar/WatchlistAddSearch.jsx
@@ -0,0 +1,76 @@
+import React, { useState } from 'react';
+
+function WatchlistAddSearch({ catalog, currentStocks, onAddStock }) {
+    const [addQuery, setAddQuery] = useState("");
+    const trimmedAddQuery = addQuery.trim();
+    const normalizedAddQuery = trimmedAddQuery.toUpperCase();
+    const currentSymbols = new Set(
+        currentStocks.map((stock) => stock.symbol.toUpperCase())
+    );
+    const addMatches = trimmedAddQuery
+        ? catalog
+            .filter((stock) =>
+                stock.symbol.toUpperCase().includes(normalizedAddQuery) &&
+                !currentSymbols.has(stock.symbol.toUpperCase())
+            )
+            .slice(0, 6)
+        : [];
+
+    const addStock = (stock) => {
+        onAddStock(stock);
+        setAddQuery("");
+    };
+
+    const handleAddSubmit = (event) => {
+        event.preventDefault();
+
+        if (addMatches.length === 0) return;
+
+        addStock(addMatches[0]);
+    };
+
+    return (
+        <div className="watchlist-add-panel">
+            <form className="watchlist-add-form" onSubmit={handleAddSubmit}>
+                <i className="fa-solid fa-magnifying-glass"></i>
+                <input
+                    type="text"
+                    value={addQuery}
+                    onChange={(event) => setAddQuery(event.target.value)}
+                    placeholder="Search and add stock"
+                    aria-label="Search and add stock"
+                />
+                <button
+                    type="submit"
+                    disabled={addMatches.length === 0}
+                    aria-label="Add selected stock"
+                >
+                    <i className="fa-solid fa-plus"></i>
+                </button>
+            </form>
+
+            {trimmedAddQuery && (
+                <div className="watchlist-add-results">
+                    {addMatches.length > 0 ? (
+                        addMatches.map((stock) => (
+                            <button
+                                type="button"
+                                key={stock.symbol}
+                                className="watchlist-add-result"
+                                onMouseDown={(event) => event.preventDefault()}
+                                onClick={() => addStock(stock)}
+                            >
+                                <span>{stock.symbol}</span>
+                                <span>NSE {"\u20B9"}{stock.prices?.NSE?.last_price}</span>
+                            </button>
+                        ))
+                    ) : (
+                        <div className="watchlist-add-empty">No available stock found</div>
+                    )}
+                </div>
+            )}
+        </div>
+    );
+}
+
+export default WatchlistAddSearch;

