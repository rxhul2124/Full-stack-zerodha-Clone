@@ -0,0 +1,41 @@
+import React from 'react';
+import Hover from './Hover';
+import MarketDepth from './MarketDepth';
+
+function WatchlistStockRow({ item, action, setAction }) {
+    const currentExchange = item.exchange || "NSE";
+    const data = item.prices[currentExchange];
+    const isNegative = data.change < 0;
+
+    return (
+        <div className="items row py-2 position-relative align-items-center border-bottom">
+            <div className={`col-5 ${isNegative ? "text-danger" : "text-success"}`}>
+                {item.symbol} <span className='exchange'>{currentExchange}</span>
+            </div>
+            <div className="col-2 hide">{data.change}</div>
+            <div className="col-2 hide">{data.percent_change}%</div>
+            <i className={`col-1 hide fa-solid fa-angle-${isNegative ? "down" : "up"} ${isNegative ? "text-danger" : "text-success"}`}></i>
+            <div className={`col-1 hide ${isNegative ? "text-danger" : "text-success"}`}>{"\u20B9"}{data.last_price}</div>
+            <Hover 
+                item={item}
+                setAction={setAction} 
+            />
+            <div
+                className={`market-depth-wrapper ${
+                    action.type === "Market Depth" &&
+                    action.item?.symbol === item.symbol
+                    ? "open"
+                    : ""
+            }`}
+            >
+                <MarketDepth
+                    depth={item?.prices?.[currentExchange]?.depth}
+                    stats={item?.prices?.[currentExchange]?.stats}
+                    lastPrice={data.last_price}
+                />
+            </div>
+        </div>
+    );
+}
+
+export default WatchlistStockRow;

