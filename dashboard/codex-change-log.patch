+const round = (value) => Number(value.toFixed(2));
+
+const createDepth = (price, direction = 1) => ({
+  bid: Array.from({ length: 5 }, (_, index) => ({
+    price: round(price - (index + 1) * direction * 0.2),
+    qty: (5 - index) * 100,
+    orders: 12 - index * 2,
+  })),
+  offer: Array.from({ length: 5 }, (_, index) => ({
+    price: round(price + (index + 1) * direction * 0.2),
+    qty: (5 - index) * 100,
+    orders: 11 - index * 2,
+  })),
+});
+
+const createMarket = (price, change, index, bseOffset = 0) => {
+  const lastPrice = round(price + bseOffset);
+  const currentChange = round(change + bseOffset * 0.25);
+  const prevClose = round(lastPrice - currentChange);
+  const high = round(Math.max(lastPrice, prevClose) + Math.max(4, lastPrice * 0.012));
+  const low = round(Math.min(lastPrice, prevClose) - Math.max(4, lastPrice * 0.012));
+
+  return {
+    last_price: lastPrice,
+    change: currentChange,
+    percent_change: round((currentChange / prevClose) * 100),
+    depth: createDepth(lastPrice, bseOffset ? 1.2 : 1),
+    stats: {
+      prev_close: prevClose,
+      open: round(prevClose + currentChange * 0.35),
+      high,
+      low,
+      volume: 42000 + index * 1375,
+      avg_price: round((high + low + lastPrice) / 3),
+      lower_circuit: round(prevClose * 0.9),
+      upper_circuit: round(prevClose * 1.1),
+      ltq: 1 + (index % 90),
+      ltt: "10:00:00 AM",
+    },
+  };
+};
+
+const wishlist = stockSeeds.map(([symbol, price, change], index) => ({
+  symbol,
+  prices: {
+    NSE: createMarket(price, change, index),
+    BSE: createMarket(price, change, index, index % 2 === 0 ? 0.45 : -0.35),
+  },
+}));
+
+export default wishlist;
