@@ -0,0 +1,52 @@
+:root{
+    --sidebar-width: 30.5%;
+    --topbar-height: 3.5rem;
+}
+
+.app-body{
+    display: grid;
+    grid-template-columns: var(--sidebar-width) minmax(0, 1fr);
+    height: calc(100vh - var(--topbar-height));
+    overflow: hidden;
+    min-height: 0;
+}
+
+.sidebar-column,
+.content-column{
+    min-width: 0;
+    min-height: 0;
+    height: 100%;
+}
+
+.sidebar-column{
+    overflow: hidden;
+}
+
+.content-column{
+    overflow: auto;
+    background-color: #ffffff;
+}
+
+.app-buy-row{
+    --bs-gutter-x: 0;
+    margin: 0;
+}
+
+@media (max-width: 992px) {
+    :root{
+        --sidebar-width: 36%;
+    }
+}
+
+@media (max-width: 768px) {
+    .app-body{
+        grid-template-columns: 1fr;
+        height: auto;
+        min-height: calc(100vh - var(--topbar-height));
+        overflow: visible;
+    }
+
+    .content-column{
+        display: none;
+    }
+}
